programa {
  funcao inicio() {
    inteiro numero1, numero2, soma
    // ler o primeiro numero
    escreva("digite o primero numero: ")
    leia(numero1)
    // ler o segundo numero
    escreva("digite o segundo numero: ")
    leia(numero2)

    // somar os dois
    soma = numero1 + numero2

    // aprensentar o resultado
    escreva(" soma é: " + soma )
  }
}
